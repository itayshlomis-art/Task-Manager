# העתק קובץ זה ל-.env.local ומלא את הערכים מ-Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key...

# מפתח סודי לצד השרת בלבד (Project Settings → API → service_role)
# נחוץ כדי לאפשר הוספת משתמשים ממסך "ניהול משתמשים". לעולם אל תחשוף אותו בצד הלקוח.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key...
